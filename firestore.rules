rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth()  { return request.auth != null; }
    function isMe(uid) { return request.auth.uid == uid; }
    function isAdmin() { return request.auth.uid == 'kW8tMNo8IkejWQsMzCnnwjgVaUa2'; }

    // ── USERS ──
    match /users/{uid} {
      allow read:   if isMe(uid) || isAdmin();
      allow create: if isMe(uid);
      allow update: if isAdmin() || (isMe(uid) &&
        !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['role','userType','banned','balance']));
      allow delete: if isAdmin();
      match /children/{cid}  { allow read,write: if isMe(uid)||isAdmin(); }
      match /growth/{id}     { allow read,write: if isMe(uid)||isAdmin(); }
      match /vaccines/{id}   { allow read,write: if isMe(uid)||isAdmin(); }
      match /milestones/{id} { allow read,write: if isMe(uid)||isAdmin(); }
      match /logs/{id}       { allow read,write: if isMe(uid)||isAdmin(); }
      match /pointsLog/{id}  { allow read: if isMe(uid)||isAdmin(); allow write: if isAdmin()||isMe(uid); }
      match /savedItems/{id} { allow read,write: if isMe(uid); }
    }

    // ── BANNERS (সবাই পড়বে, Admin লিখবে) ──
    match /banners/{id} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ── GIFTS (সবাই পড়বে, Admin লিখবে) ──
    match /gifts/{id} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ── COMMUNITY POSTS ──
    match /posts/{pid} {
      allow read:   if isAuth();
      allow create: if isAuth() && request.resource.data.authorId == request.auth.uid;
      allow update: if isAdmin() || (isAuth() && resource.data.authorId == request.auth.uid);
      allow delete: if isAdmin() || (isAuth() && resource.data.authorId == request.auth.uid);
      match /comments/{cid} {
        allow read:   if isAuth();
        allow create: if isAuth() && request.resource.data.authorId == request.auth.uid;
        allow delete: if isAdmin() || (isAuth() && resource.data.authorId == request.auth.uid);
      }
      match /likes/{lid} {
        allow read:  if isAuth();
        allow write: if isAuth() && lid == request.auth.uid;
      }
    }

    // ── PRODUCTS (Admin লিখবে, login করলে পড়বে) ──
    match /products/{id} {
      allow read:  if isAuth();
      allow write: if isAdmin();
      match /reviews/{rid} {
        allow read:   if isAuth();
        allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
        allow delete: if isAdmin() || (isAuth() && resource.data.userId == request.auth.uid);
      }
    }

    // ── ORDERS ──
    match /orders/{id} {
      allow read:   if isAdmin() || (isAuth() && resource.data.userId == request.auth.uid);
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid
                    && request.resource.data.status == 'pending';
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── EBOOKS ──
    match /ebooks/{id} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ── EARN / POINTS ──
    match /loginBonuses/{uid} {
      allow read,write: if isMe(uid) || isAdmin();
    }
    match /pointsLog/{id} {
      allow read:  if isAuth() && resource.data.userId == request.auth.uid;
      allow write: if isAdmin() || isAuth();
    }

    // ── NOTIFICATIONS ──
    match /notifications/{id} {
      allow read:   if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAdmin();
      allow update: if isAuth() && resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // ── TRANSACTIONS ──
    match /transactions/{id} {
      allow read:   if isAdmin() || (isAuth() && resource.data.userId == request.auth.uid);
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update,delete: if isAdmin();
    }

    // ── REFERRALS ──
    match /referrals/{id} {
      allow read:   if isAdmin() || isAuth();
      allow create: if isAuth();
      allow update,delete: if isAdmin();
    }

    // ── TOURNAMENTS ──
    match /tournaments/{id} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() || isAdmin();
      allow delete: if isAdmin();
    }

    // ── APP CONTENT (Admin controls) ──
    match /appSettings/{id} { allow read: if true; allow write: if isAdmin(); }
    match /healthTips/{id}  { allow read: if true; allow write: if isAdmin(); }
    match /newsletter/{id}  { allow read: if isAdmin(); allow create: if isAuth(); allow update,delete: if isAdmin(); }
  }
}
